# Copy to .env.local for local dev; set the same keys in Vercel project settings.

# Postgres connection string (provisioned via Vercel → Neon integration)
DATABASE_URL=

# football-data.org token — goals, scorers, fixtures, bracket
# https://www.football-data.org/client/register
FOOTBALL_DATA_TOKEN=

# API-Football key — cards only
# https://dashboard.api-football.com
API_FOOTBALL_KEY=

# Shared secret guarding /api/cron/ingest (Vercel Cron sends it as a Bearer token)
CRON_SECRET=
